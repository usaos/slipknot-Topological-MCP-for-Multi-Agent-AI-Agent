# ========== Slipknot V4.1 Lite 环境变量配置 ==========
# 复制为 .env 文件后修改，或直接通过系统环境变量设置

# ========== 服务配置 ==========
# 服务监听端口
PORT=8000

# 工作线程数（TDA计算并发度）
MAX_WORKERS=4

# ========== 鉴权配置 ==========
# Agent 访问 Token（生产环境务必修改为强随机字符串）
AGENT_TOKEN=enterprise-agent-key-2026

# ========== 存储配置（可选） ==========
# 是否启用Redis存储（0=内存模式，1=Redis模式）
USE_REDIS=0

# Redis 连接配置（USE_REDIS=1 时生效）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# ========== 安全沙箱配置 ==========
# 允许读取的CSV文件目录（多个用冒号分隔）
# SAFE_PATHS=/data/safe_zone:./tmp

# ========== 日志配置 ==========
# 审计日志文件路径
# AUDIT_LOG_PATH=./slipknot_audit.log
